# PostgreSQL
POSTGRES_USER=docuser
POSTGRES_PASSWORD=docpassword
POSTGRES_DB=docprocessing
DATABASE_URL=postgresql+asyncpg://docuser:docpassword@db:5432/docprocessing

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# JWT — сгенерируй: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_PLEASE_GENERATE_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# App
APP_NAME=Document Processing System
DEBUG=true
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=50

# Tesseract
TESSERACT_CMD=/usr/bin/tesseract
TESSERACT_LANG=rus+eng

# HuggingFace — модель эмбеддингов
# Используем multilingual модель (работает без токена)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
HF_HOME=/root/.cache/huggingface
# HF_TOKEN=hf_xxx  # нужен только для приватных моделей
